# Chave da API Groq para o backend
GROQ_API_KEY=your_groq_api_key_here
# Modelo padrão usado pelo backend
GROQ_MODEL=llama-3.3-70b-versatile
# Modelo vision compatível com imagens, caso use uploads
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Chave da API Pexels usada para buscar imagens de plantas/objetos botânicos
PEXELS_API_KEY=your_pexels_api_key_here
